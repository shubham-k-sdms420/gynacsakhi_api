# --- Required ---
GEMINI_API_KEY=your_actual_api_key_here

# --- Gemini generation (change without touching code) ---
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.6
GEMINI_MAX_OUTPUT_TOKENS=600

# --- Token usage logging (JSONL) ---
# true / false
TOKEN_LOG_ENABLED=true
# Where to append one JSON object per conversation turn
TOKEN_LOG_PATH=sakhi_tokens.jsonl

# --- Optional: external knowledge / persona (UTF-8 text files).
# If unset, built-in defaults from context_data.py are used.
# CLINIC_CONTEXT_PATH=/absolute/or/relative/path/to/clinic_context.txt
# SYSTEM_PROMPT_PATH=/absolute/or/relative/path/to/system_prompt.txt

# --- Local server when using: python main.py ---
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
# true / false
UVICORN_RELOAD=false

# --- OpenAPI metadata ---
APP_TITLE=Sakhi Clinic Assistant API
APP_DESCRIPTION=AI-powered assistant for Shakti Women's Care Clinic
APP_VERSION=1.0.0
