# ---------------------------------------------------------------------------
# Inference provider selection
# Set INFERENCE_PROVIDER to either:
#   gemini      — use Google Gemini (default)
#   openrouter  — use OpenRouter (OpenAI-compatible API)
# INFERENCE_MODEL overrides the default model for the chosen provider.
# ---------------------------------------------------------------------------
INFERENCE_PROVIDER=gemini
# INFERENCE_MODEL=                 # leave blank to use provider's own default

# --- Gemini (used when INFERENCE_PROVIDER=gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.6
GEMINI_MAX_OUTPUT_TOKENS=600

# --- OpenRouter (used when INFERENCE_PROVIDER=openrouter) ---
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TEMPERATURE=0.6
# OPENROUTER_MAX_OUTPUT_TOKENS=600

# --- Token usage logging (JSONL) ---
# true / false
TOKEN_LOG_ENABLED=true
# Where to append one JSON object per conversation turn
TOKEN_LOG_PATH=sakhi_tokens.jsonl

# --- Optional: external knowledge / persona (UTF-8 text files).
# If unset, built-in defaults from context_data.py are used.
# CLINIC_CONTEXT_PATH=/absolute/or/relative/path/to/clinic_context.txt
# SYSTEM_PROMPT_PATH=/absolute/or/relative/path/to/system_prompt.txt

# --- Local server when using: python main.py ---
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
# true / false
UVICORN_RELOAD=false

# --- OpenAPI metadata ---
APP_TITLE=Sakhi Clinic Assistant API
APP_DESCRIPTION=AI-powered assistant for Shakti Women's Care Clinic
APP_VERSION=1.0.0
